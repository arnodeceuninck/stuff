# Copy to .env and fill in real values — never commit .env.
#
# The DATABASE_URL key maps directly to the Docker secret name (database_url)
# via backend-framework/scripts/create-secrets.ps1 (lowercases every key).

# PostgreSQL container — only used by compose.override.yml, not mounted as a Docker secret
POSTGRES_PASSWORD=change-me

# Service secrets — each becomes secrets/<lowercase-key> for Docker to mount
DATABASE_URL=postgresql+asyncpg://stuff:change-me@postgres:5432/stuff_auth
AUTH_SECRET=change-me-to-at-least-32-random-characters
