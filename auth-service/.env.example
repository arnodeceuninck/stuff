# Copy to .env and fill in real values. Never commit .env.

# Database connection string (credentials included — keep secret)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/auth_db

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=replace-with-random-256-bit-hex

# Optional: Grafana Alloy / Loki push endpoint
# GRAFANA_PUSH_URL=http://localhost:3100/loki/api/v1/push

# Token lifetimes (defaults shown)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30
