# Copy to .env and fill in real values. Never commit .env.

# Database connection string (credentials included — keep secret)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/backend_db

# JWT signing secret — must match the value used by auth-service
AUTH_SECRET=replace-with-random-256-bit-hex

# Optional: Grafana Alloy / Loki push endpoint
# GRAFANA_PUSH_URL=http://localhost:3100/loki/api/v1/push

# App-specific flags (defaults shown)
# MY_APP_SPECIFIC_FLAG=false
