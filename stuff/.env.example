# Copy to .env and fill in real values — never commit .env.
#
# The DATABASE_URL key maps directly to the Docker secret name (database_url)
# via create-secrets.ps1, which lowercases every key.

# PostgreSQL container — only used by compose.override.yml, not mounted as a secret
POSTGRES_PASSWORD=change-me

# Service secrets — each becomes a file in secrets/ with the lowercase filename
DATABASE_URL=postgresql+asyncpg://stuff:change-me@postgres:5432/stuff_backend
AUTH_SECRET=change-me-to-at-least-32-random-characters
AUTH_SERVICE_URL=http://host.docker.internal:8001
